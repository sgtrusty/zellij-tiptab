load_plugins {
    "file:target/wasm32-wasip1/release/zellij-tiptab.wasm"
}

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar" {
                show_help_hints false
            }
        }
    }

    pane size=1 borderless=true { plugin location="zellij:tab-bar"; }

    pane {
        split_direction "vertical"

        pane {
            pane name="SPACE" {
                command "bash"
                args "-c" "sleep 1 && zellij action close-pane --pane-id $ZELLIJ_PANE_ID"
            }
        }

        pane {
            pane name="LOGS" {
                command "bash"
                args "-c" "tail -f /tmp/zellij-1000/zellij-log/zellij.log"
            }
            pane stacked=true {
                pane size="10%" name="RELOAD PLUGIN (DOCKER)" {
                    command "bash"
                    args "-c" "make docker-build && zellij action start-or-reload-plugin file:target/wasm32-wasip1/release/zellij-tiptab.wasm"
                }
            }
        }
    }

    pane size="10%" name="TIPTAB" {
        pane name="CMD" focus=true {
            command "bash"
            args "-c" "bash && zellij action close-tab"
        }
    }
}
